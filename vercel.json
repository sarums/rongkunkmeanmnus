{
  "routes": [
    { "src": "/admin",         "dest": "/admin.html" },
    { "src": "/about",         "dest": "/pages.html" },
    { "src": "/privacy",       "dest": "/pages.html" },
    { "src": "/terms",         "dest": "/pages.html" },
    { "src": "/contact",       "dest": "/pages.html" },
    { "src": "/watch/([^/]+)/([^/]+)", "dest": "/index.html" },
    { "src": "/watch/([^/]+)", "dest": "/index.html" },
    { "src": "/search",        "dest": "/index.html" },
    { "src": "/history",       "dest": "/index.html" },
